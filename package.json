{
  "name": "sofia-guide",
  "version": "1.0.0",
  "description": "Mobiler Reiseführer für Sofia-Wochenendtrip (Mai 2026)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
